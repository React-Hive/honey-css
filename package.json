{
  "name": "@react-hive/honey-css",
  "version": "1.18.0",
  "description": "A lightweight CSS tokenizer and parser that produces a simple AST for custom CSS processing.",
  "keywords": [
    "css",
    "parser",
    "tokenizer",
    "ast",
    "css-ast",
    "css-in-js",
    "compiler",
    "transformer",
    "react-hive",
    "honey-style"
  ],
  "homepage": "https://github.com/React-Hive/honey-css",
  "bugs": {
    "url": "https://github.com/React-Hive/honey-css/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/React-Hive/honey-css.git"
  },
  "author": "Mike Aliinyk <m.aliynik@gmail.com>",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf dist coverage",
    "build": "webpack --config webpack.config.mjs",
    "test": "vitest",
    "prepublishOnly": "CI=1 pnpm clean && pnpm test && pnpm build"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@react-hive/honey-utils": "4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@mdx-js/loader": "3.1.1",
    "@types/node": "24.12.4",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "10.4.1",
    "eslint-plugin-react": "7.37.5",
    "prettier": "3.8.3",
    "ts-loader": "9.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3"
  }
}
